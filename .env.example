# PostgreSQL / Neon / Supabase
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full"

# Auth.js / NextAuth. Production must use a stable random value.
AUTH_SECRET="change-me-to-a-long-random-secret"
NEXTAUTH_SECRET="change-me-to-a-long-random-secret"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# UI switches
NEXT_PUBLIC_ENABLE_REMOTE_BACKGROUND=true
NEXT_PUBLIC_ENABLE_ADMIN_BACKGROUND=false
NEXT_PUBLIC_AUTO_INIT_DB=false
CONFIG_CACHE_TTL_MS=5000
PREVIEW_IDS_CACHE_TTL_MS=60000

# Vercel compatibility
NODEJS_HELPERS=0
